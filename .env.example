# Copy this file to `.env.local` and fill in your key.
# `.env.local` is git-ignored and loaded automatically at runtime.

# Required: your Anthropic API key (https://console.anthropic.com/).
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: override the default model (defaults to claude-sonnet-4-6).
# ANTHROPIC_MODEL=claude-opus-4-8

# Optional: override the API base URL (e.g. a gateway/proxy).
# ANTHROPIC_BASE_URL=https://api.anthropic.com
