# Copy this file to `.env.local` and fill in your key.
# `.env.local` is git-ignored and loaded automatically at runtime.

# Required: your Anthropic API key (https://console.anthropic.com/).
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: override the default model (defaults to claude-sonnet-4-6).
# ANTHROPIC_MODEL=claude-opus-4-8

# Optional: override the API base URL (e.g. a gateway/proxy).
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# HydraDB — agent memory layer for the skill-feedback learning loop.
# Get a key at https://dashboard.hydradb.com and create a tenant.
HYDRA_DB_API_KEY=sk_live_your-key-here
HYDRA_TENANT_ID=default-tenant
# Per-reviewer memory namespace. Use a fresh value for a clean demo slate.
HYDRA_SUB_TENANT=controller
